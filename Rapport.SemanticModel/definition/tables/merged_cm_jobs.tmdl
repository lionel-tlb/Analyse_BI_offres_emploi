				    #"Espaces supprimés2" = Table.TransformColumns(#"Espaces supprimés1",{{"contrat", Text.Trim, type text}, {"region", Text.Trim, type text}, {"salaire", Text.Trim, type text}, {"source", Text.Trim, type text}, {"lien offre", Text.Trim, type text}}),
				    #"Valeur remplacée3" = Table.ReplaceValue(#"Espaces supprimés2","Tout-le-cameroun","Tout_le_cameroun",Replacer.ReplaceText,{"region"}),
