				    #"Valeur remplacée8" = Table.ReplaceValue(#"Valeur remplacée7","02 chauffeurs","Chauffeur",Replacer.ReplaceText,{"poste"}),
				    #"Valeur remplacée9" = Table.ReplaceValue(#"Valeur remplacée8","03 chauffeurs","Chauffeur",Replacer.ReplaceText,{"poste"}),
